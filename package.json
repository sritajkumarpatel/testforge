{
  "name": "testforge",
  "version": "2.0.0",
  "description": "AI-powered test case generation for Azure DevOps — multi-agent, multi-LLM",
  "keywords": [
    "azure-devops",
    "test-automation",
    "ai-testing",
    "test-case-generator",
    "llm",
    "qa-automation",
    "playwright",
    "bdd",
    "agile-testing",
    "software-testing",
    "quality-engineering",
    "test-management",
    "ollama",
    "openai",
    "claude",
    "gemini",
    "gherkin"
  ],
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "LOG_LEVEL=silent jest",
    "test:watch": "LOG_LEVEL=silent jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.44.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
