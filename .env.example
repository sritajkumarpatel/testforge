# ── TestForge — Environment Configuration ────────────────────────────────────
# Copy this file to .env and fill in your values.

# Server port (default: 3010)
PORT=3010

# ── Azure DevOps ──────────────────────────────────────────────────────────────
# Default ADO organisation and project (pre-fills the Settings inputs).
ADO_ORG=
ADO_PROJECT=

# ── Chrome / Edge Path ────────────────────────────────────────────────────────
# Full path to the browser executable. Auto-detected if left empty.
# Examples:
#   macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
#   Linux:   /usr/bin/google-chrome
CHROME_PATH=

# Set to any value to keep Chrome open after test case creation (default: off)
# KEEP_CHROME_OPEN=true

# ── LLM Provider: Ollama (Local) ──────────────────────────────────────────────
# Defaults: http://localhost:11434, model: llama3.2
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── LLM Provider: OpenAI ──────────────────────────────────────────────────────
# Get your API key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── LLM Provider: Anthropic Claude ────────────────────────────────────────────
# Get your API key at https://console.anthropic.com/
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ── LLM Provider: Google Gemini ───────────────────────────────────────────────
# Get your API key at https://aistudio.google.com/apikey
# GOOGLE_API_KEY=AIza...
# GOOGLE_MODEL=gemini-2.0-flash

# ── LLM Provider: OpenCode ────────────────────────────────────────────────────
# OPENCODE_API_KEY=oc-...
# OPENCODE_URL=https://api.opencode.ai/v1
# OPENCODE_MODEL=deepseek-v4-flash-free
